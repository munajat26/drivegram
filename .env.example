# ============================================================
# DRIVEGRAM - Environment Variables
# ============================================================
# Salin file ini menjadi .env.local dan isi nilainya

# URL Google Apps Script Web App (dapatkan setelah deploy GAS)
# Cara mendapatkan: Deploy > New Deployment > Web App > Copy URL
NEXT_PUBLIC_GAS_URL=https://script.google.com/macros/s/YOUR_SCRIPT_ID/exec
